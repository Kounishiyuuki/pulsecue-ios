# Copy this file to `.dev.vars` for local `wrangler dev` runs.
# `.dev.vars` is git-ignored; this `.example` template is committed.
# Never put a real production secret in either file — use
# `wrangler secret put <NAME>` for production.

# Bearer token required for POST /api/gym-machines/import.
# Any non-empty value works locally; it just has to match the token
# you send in the `Authorization: Bearer` header while testing.
PULSECUE_IMPORT_API_KEY=local-dev-dummy-key

# HMAC-SHA256 signing secret used by POST /api/auth/import-token to
# mint short-lived bearer tokens. Must be different from
# PULSECUE_IMPORT_API_KEY. Any non-empty random-ish value works
# locally; production must use `wrangler secret put
# PULSECUE_IMPORT_TOKEN_SECRET` with a strong random value.
PULSECUE_IMPORT_TOKEN_SECRET=local-dev-token-signing-secret
